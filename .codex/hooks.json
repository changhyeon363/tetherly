{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.venv/bin/co-agent codex-permission-request",
            "statusMessage": "sending permission request to Discord"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.venv/bin/co-agent codex-stop",
            "statusMessage": "sending turn-complete notice to Discord"
          }
        ]
      }
    ]
  }
}
